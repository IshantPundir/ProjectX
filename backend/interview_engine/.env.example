LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

DEEPGRAM_API_KEY=
OPENAI_API_KEY=
CARTESIA_API_KEY=

# -- Observability ---------------------------------------------------------
# log_audio_events is True by default (metadata only, safe in any env).
# Flip log_user_transcripts to true ONLY in dev/local — it adds verbatim
# STT transcripts, LLM message bodies, and tool args/outputs to log
# records. Those fields are PII per the root CLAUDE.md discipline; never
# enable in production.
INTERVIEW_LOG_AUDIO_EVENTS=true
INTERVIEW_LOG_USER_TRANSCRIPTS=false