.git
.gitignore
*.md
.env*
__pycache__
*.pyc
.mypy_cache
.ruff_cache
.pytest_cache
.venv
# Local HF/model cache must never enter the build context — models are
# downloaded into the image at /opt/hf-cache by the Dockerfile, not copied
# from the host. Keeps the context small and avoids stale-model bleed-in.
.cache
