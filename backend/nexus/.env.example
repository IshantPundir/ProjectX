# === Nexus Backend Environment Variables ===
# Copy to .env and fill in real values for local development.

# App
DEBUG=true
ENVIRONMENT=development

# Database (asyncpg)
DATABASE_URL=postgresql+asyncpg://projectx:projectx@postgres:5432/projectx

# Redis
REDIS_URL=redis://redis:6379/0

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
CANDIDATE_JWT_SECRET=change-me-candidate-secret

# Supabase Auth (dashboard users)
SUPABASE_URL=
SUPABASE_JWT_SECRET=

# LiveKit
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# AI — Anthropic
ANTHROPIC_API_KEY=

# STT — Deepgram
DEEPGRAM_API_KEY=

# TTS — Cartesia
CARTESIA_API_KEY=

# Notifications — Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@projectx.com

# Notifications — SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Observability
SENTRY_DSN=
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# CORS
CORS_ORIGINS=["http://localhost:3000"]
