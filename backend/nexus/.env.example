# === Nexus Backend Environment Variables ===
# Copy to .env and fill in real values for local development.

# App
DEBUG=true
ENVIRONMENT=development

# Database (asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/postgres

# Per-request runtime PG role. The `postgres` role in Supabase has
# rolbypassrls=true, so every RLS policy in the schema is a no-op as long
# as the app connects as postgres. Setting DB_RUNTIME_ROLE=nexus_app
# causes each get_tenant_db / get_bypass_db session to `SET LOCAL ROLE
# nexus_app` before running any queries. nexus_app is created by
# alembic migration 0010 with NOBYPASSRLS — its queries are subject to
# the full tenant_isolation + service_bypass policy pair.
#
# Leave empty when first bootstrapping a new cluster (migrations must run
# before the role exists). Set to nexus_app after `alembic upgrade head`.
DB_RUNTIME_ROLE=nexus_app

# Test database (separate DB, same PostgreSQL instance)
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/projectx_test

# Redis
REDIS_URL=redis://redis:6379/0

# Auth — ES256 JWKS verification
SUPABASE_JWKS_URL=http://127.0.0.1:54321/auth/v1/.well-known/jwks.json

# Expected JWT issuer (`iss` claim). If unset, defaults to
# `{SUPABASE_URL}/auth/v1`. Set this explicitly when the network-reachable
# Supabase URL differs from the issuer Supabase advertises in tokens — the
# common dev case is Docker, where the backend reaches Supabase via
# `host.docker.internal` but Supabase's GoTrue process stamps `iss` with
# `127.0.0.1` (its own self-view). Mismatch → "Invalid issuer" 401 on
# every request. Production on Supabase Cloud usually doesn't need this.
SUPABASE_JWT_ISSUER=http://127.0.0.1:54321/auth/v1

# Candidate JWT signing secret — REQUIRED, no default.
# Generate with: openssl rand -hex 32
# Treat with the same sensitivity as a DB credential. Signs single-use
# candidate session JWTs (HS256, hardcoded in app/modules/auth/service.py).
CANDIDATE_JWT_SECRET=

# ATS integration — encrypts ATS connection credentials at rest.
# Comma-separated list of Fernet keys; the first key is used to encrypt new
# values. Add a new key to the front to start a rotation; old keys remain
# available for decrypting historical ciphertexts.
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ATS_CREDENTIALS_ENCRYPTION_KEYS=
ATS_DEFAULT_RETRY_AFTER_SECONDS=60
# Minimum seconds between consecutive HTTP requests to a single ATS vendor.
# Default 2.0s (= 0.5 req/s sustained). Prevents Ceipal's undocumented 429
# rate limit. Per-connection override via ats_connections.rate_limit_qps.
ATS_DEFAULT_REQUEST_PACING_SECONDS=2.0

# Notifications
NOTIFICATIONS_DRY_RUN=true

# LiveKit
# LIVEKIT_URL — backend-side (server-to-server: token mint, agent dispatch).
#   Local dev with host-installed `livekit-server --dev`:
#     ws://host.docker.internal:7880
#   Cloud: wss://<project>.livekit.cloud
# LIVEKIT_PUBLIC_URL — what the candidate browser receives in /start.
#   Local dev: ws://localhost:7880
#   Cloud / single-host deploys: leave empty (falls back to LIVEKIT_URL).
# Local --dev mode hardcodes API_KEY=devkey, API_SECRET=secret.
LIVEKIT_URL=
LIVEKIT_PUBLIC_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Interview engine (Phase 3 merged: in-process, no HTTP boundary) ---

# Agent name and state machine tuning
ENGINE_AGENT_NAME=Sam

# Turn detection / endpointing.
# 3.0s is LiveKit's documented default (Phase 5, 2026-05-12).
# Earlier tuning (unlikely_threshold→0.5, min_duration→1.0s) stabilized EOU
# detection; long-pause tolerance now lives in the upstream EOU layer
# (MultilingualModel + endpointing) — orchestrator-side coalescing was
# removed in this phase.
# Tune down for tight back-and-forth, up if candidates need mid-thought pauses.
#
# 2026-05-17 update: switched mode "fixed"→"dynamic" so the framework
# computes an EMA over per-session pause statistics. min/max are the
# bounds the EMA adapts within. Headroom raised to 4.5s so 3+ s thinking
# pauses don't fire premature EOUs (see the conversational-continuation
# design at docs/superpowers/specs/2026-05-17-conversational-continuation-design.md).
ENGINE_ENDPOINTING_MODE=dynamic
ENGINE_ENDPOINTING_MIN_DELAY=0.8
ENGINE_ENDPOINTING_MAX_DELAY=4.5

# --- Conversational continuation (2026-05-17, updated 2026-05-17) ----------
# Pre-Speaker cancellation watcher: when STT delivers a final transcript
# with at least ENGINE_CONTINUATION_MIN_WORD_COUNT words during an
# in-flight turn AND the agent has not yet started speaking, the Judge
# task is cancelled, the State Engine is rolled back to the pre-turn
# snapshot, and the candidate's text is buffered for stitching into the
# next turn. See spec at
# docs/superpowers/specs/2026-05-17-conversational-continuation-design.md.
#
# Trigger switched from VAD (sustained user_state speaking) to STT-final
# after session 7970e91c showed VAD-triggered aborts on non-speech sounds
# and brief filler interjections like "uh okay".
#
# ENGINE_CONTINUATION_ENABLED is the kill switch — set to false for
# emergency rollback without a code deploy.
ENGINE_CONTINUATION_ENABLED=true
ENGINE_CONTINUATION_MIN_WORD_COUNT=2
ENGINE_CONTINUATION_CONSECUTIVE_ABORT_CAP=3

# Observability
ENGINE_LOG_AUDIO_EVENTS=true
ENGINE_LOG_USER_TRANSCRIPTS=false

# Engine — structured agent (added 2026-05-07)
ENGINE_JUDGE_MODEL=gpt-5.4-mini-2026-03-17
ENGINE_SPEAKER_MODEL=gpt-5.4-nano-2026-03-17
# 10s gives gpt-5.4-mini comfortable margin for strict json_schema structured output (typical: 3-5s + retry headroom).
ENGINE_JUDGE_TOTAL_BUDGET_MS=10000
ENGINE_JUDGE_RETRY_WAIT_MS=250
ENGINE_SPEAKER_MAX_OUTPUT_TOKENS=200
ENGINE_CHECKPOINT_TURNS=10
ENGINE_CHECKPOINT_SECONDS=30

ENGINE_CLAIMS_POOL_MAX=50
ENGINE_JUDGE_PROMPT_VERSION=v2
ENGINE_SPEAKER_PROMPT_VERSION=v2

# Interview engine v2 — EOU / turn-taking (isolated from v1; tune on talk-tests).
ENGINE_V2_TURN_DETECTOR_UNLIKELY_THRESHOLD=0.5
ENGINE_V2_ENDPOINTING_MODE=dynamic
ENGINE_V2_ENDPOINTING_MIN_DELAY=0.8
ENGINE_V2_ENDPOINTING_MAX_DELAY=4.5
ENGINE_V2_HOLD_SPACE_ENABLED=true
ENGINE_V2_HOLD_SPACE_DELAY_S=2.5
ENGINE_V2_HOLD_SPACE_MESSAGE=Take your time.
ENGINE_V2_UNRESPONSIVE_PROMPT_1_S=7.0
ENGINE_V2_UNRESPONSIVE_PROMPT_2_S=15.0
ENGINE_V2_UNRESPONSIVE_MAX_NO_RESPONSES=2
ENGINE_V2_UNRESPONSIVE_MESSAGE_1=Whenever you're ready.
ENGINE_V2_UNRESPONSIVE_MESSAGE_2=Are you still there?
ENGINE_V2_BACKCHANNEL_MIN_WORDS=2
ENGINE_V2_MOUTH_SCENARIO=

# Interview engine v2 (two-plane). Default selection stays v1.
INTERVIEW_ENGINE_DEFAULT_VERSION=v1
ENGINE_BRAIN_MODEL=gpt-5.4-2026-03-05
ENGINE_BRAIN_EFFORT=low
ENGINE_MOUTH_MODEL=gpt-5.4-mini-2026-03-17
ENGINE_MOUTH_EFFORT=
ENGINE_BRAIN_PROMPT_VERSION=v3
ENGINE_MOUTH_PROMPT_VERSION=v3
ENGINE_BRAIN_PROMPT_CACHE_KEY=brain:v1
ENGINE_MOUTH_PROMPT_CACHE_KEY=mouth:v1
# v2 mouth persona display name (design default "Arjun"; blank -> ENGINE_AGENT_NAME).
ENGINE_MOUTH_PERSONA_NAME=Arjun

# Canned terminal message played to the candidate after the session lifecycle
# has entered 'closing' or 'closed' (e.g. polite_close was already delivered
# but the candidate keeps talking). {candidate_name} interpolates to the
# candidate's first name; falls back gracefully if name is empty.
ENGINE_SESSION_ENDED_MESSAGE=Thanks for your time, {candidate_name}. This session has ended; the recruitment team will be in contact with you.

# Phase 1 — engine event log sink. `local` writes JSON to ENGINE_EVENT_LOG_DIR;
# `s3` writes to AWS_S3_BUCKET_ENGINE_EVENTS; `none` disables the writer.
ENGINE_EVENT_LOG_SINK=local
ENGINE_EVENT_LOG_DIR=/tmp/engine-events
# `metadata` strips all PII content from the envelope (production default).
# `full` keeps verbatim transcripts + LLM bodies — consent-gated audit replay only.
ENGINE_EVENT_LOG_REDACTION=metadata
# Required when ENGINE_EVENT_LOG_SINK=s3. Bucket must have versioning ON.
AWS_S3_BUCKET_ENGINE_EVENTS=

# Realtime AI models (read by app/ai/realtime.py factories).
#
# INTERVIEW_REASONING_EFFORT is forwarded to openai.LLM only when set.
# Non-reasoning chat models (*-chat-latest) reject the parameter with
# HTTP 400, so leave this BLANK for the default chat model below.
#
# Set it to one of {none|minimal|low|medium|high|xhigh} only when
# switching to a reasoning model (gpt-5.1, o3, o4-mini, gpt-5-pro, …).
# Each model has its own allowed subset — see OpenAI's API docs.
INTERVIEW_LLM_MODEL=gpt-5.3-chat-latest
INTERVIEW_REASONING_EFFORT=

# STT — provider-switchable. Default deepgram (nova-3, en-IN, with per-session
# keyterm prompting — see
# docs/superpowers/specs/2026-05-19-deepgram-keyterm-migration-design.md).
# Keyterms are LLM-extracted at bank-generation time and cached on
# stage_question_banks.extracted_keyterms. The engine merges them with the
# candidate's first name at session start.
# To switch to Sarvam (alternate, e.g. for code-mix Hindi/English candidates):
# set INTERVIEW_STT_PROVIDER=sarvam, INTERVIEW_STT_MODEL=saaras:v3,
# INTERVIEW_STT_LANGUAGE=en-IN, INTERVIEW_STT_MODE=codemix.
# INTERVIEW_STT_MODE applies to Sarvam only.
INTERVIEW_STT_PROVIDER=deepgram
INTERVIEW_STT_MODEL=nova-3
INTERVIEW_STT_LANGUAGE=en-IN
INTERVIEW_STT_MODE=transcribe

# TTS — provider-switchable. Default sarvam (bulbul:v3, speaker shubh, en-IN).
# To use OpenAI (gpt-4o-mini-tts): set INTERVIEW_TTS_PROVIDER=openai AND
# INTERVIEW_TTS_MODEL=gpt-4o-mini-tts AND INTERVIEW_TTS_VOICE=ash.
# To use Cartesia (sonic-2): set INTERVIEW_TTS_PROVIDER=cartesia AND
# INTERVIEW_TTS_MODEL=sonic-2 AND INTERVIEW_TTS_VOICE=<cartesia-voice-uuid>.
# Voice/speaker values are provider-specific:
#   sarvam   — speaker names (e.g. shubh, anushka). bulbul:v3 default speaker shubh.
#   openai   — preset names: alloy / ash / ballad / coral / echo / fable /
#              nova / onyx / sage / shimmer
#   cartesia — voice UUIDs (e.g. f8f5f1b2-f02d-4d8e-a40d-fd850a487b3d)
# INTERVIEW_TTS_PACE / INTERVIEW_TTS_TEMPERATURE apply to Sarvam only.
INTERVIEW_TTS_PROVIDER=sarvam
INTERVIEW_TTS_MODEL=bulbul:v3
INTERVIEW_TTS_VOICE=shubh
INTERVIEW_TTS_LANGUAGE=en-IN
INTERVIEW_TTS_PACE=1.0
INTERVIEW_TTS_TEMPERATURE=0.6

# Caps in-flight TTS synthesis during the opener-cache prewarm (one
# burst of ~76 calls on the first session per worker) and the
# per-session intro line. Sized to fit inside the provider's per-second
# rate-limit window. Default 4 is conservative for Sarvam's starter
# tier; raise on higher-quota tiers to reduce first-session warmup
# latency. Range [1, 16] (enforced at startup).
INTERVIEW_TTS_PREWARM_CONCURRENCY=4

# End-of-utterance confidence floor for the multilingual turn detector.
# Leave unset to let the plugin use its per-language tuned defaults
# (~0.3-0.5) — more patient AND more accurate than a hand-picked override.
# Set explicitly (0.0 – 1.0) only when you have a tuning reason; lower
# values make the agent more eager to commit turn-end, higher values
# more patient. Sarvam path (2026-05-12) recommends 0.5 for patience.
INTERVIEW_TURN_DETECTOR_UNLIKELY_THRESHOLD=0.5

# --- Audio pipeline (LK Cloud locked, 2026-05-06) ---
# Architecture is locked to LK Cloud's media plane + ML services
# (adaptive interruption + ai-coustics noise cancellation + ai-coustics
# built-in VAD). Silero and Krisp are removed from the container.
# Set ai_coustics_quail (default, background noise suppression) or
# ai_coustics_quail_vf (voice isolation — kills other voices in the room).
INTERVIEW_NOISE_CANCELLATION=ai_coustics_quail
INTERVIEW_NC_ENHANCEMENT_LEVEL=0.5


# AI — Anthropic
ANTHROPIC_API_KEY=

# --- OpenAI (Phase 2A) ---
OPENAI_API_KEY=
OPENAI_EXTRACTION_MODEL=gpt-5.2
OPENAI_EXTRACTION_EFFORT=medium

# Fast/cheap model for the per-bank STT keyterm extraction call. Runs
# once per bank generation; result is cached in
# stage_question_banks.extracted_keyterms. Default matches the nano-class
# speaker model.
OPENAI_QUESTION_BANK_KEYTERM_MODEL=gpt-5.4-nano-2026-03-17
# Bank-gen prompt set version (spoken-question rewrite). v1 = legacy written-exam prompts.
QUESTION_BANK_PROMPT_VERSION=v2

# STT (rollback) — Deepgram
DEEPGRAM_API_KEY=

# TTS (alternate) — Cartesia
CARTESIA_API_KEY=

# STT/TTS (default) — Sarvam.ai
SARVAM_API_KEY=

# Notifications — Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@projectx.com

# Notifications — SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Observability
SENTRY_DSN=

# OpenTelemetry — vendor-neutral LLM + HTTP tracing.
#
# Two opt-in exporters; both off by default. Production-safe: with neither
# set, no traces ship anywhere — spans are created in memory and discarded.
#
# Local dev: set OTEL_DEV_CONSOLE_EXPORTER=true to dump every span to stdout.
#   Useful for eyeballing what the OpenAI auto-instrumentor captures
#   (model, prompt name+version, tenant id, correlation id, latency).
#
# Production: set OTEL_EXPORTER_OTLP_ENDPOINT=<url> to ship to an OTLP
#   receiver. Compatible with Sentry (when wired), Jaeger, Tempo,
#   Datadog Agent, Honeycomb, or a custom collector that writes spans
#   to your own database for an admin-dashboard observability UI.
#
# OTEL_SERVICE_NAME defaults to "nexus" — override per-deployment if needed
# (e.g. "nexus-prod" vs "nexus-staging") to filter in the backend.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_DEV_CONSOLE_EXPORTER=false
OTEL_SERVICE_NAME=nexus

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002","http://127.0.0.1:3000","http://127.0.0.1:3001","http://127.0.0.1:3002"]

# Frontend base URL — used to build invite/confirmation links in outbound
# emails. Set PER environment: dev, staging, and production must all
# point at their own frontend host. Previously hardcoded as
# `debug ? localhost : app.projectx.com`, which silently sent staging
# invites to the production domain.
FRONTEND_BASE_URL=http://localhost:3000

# Candidate session origin — used to build /interview/{token} links in
# scheduler invite/resend emails. Must point at the frontend/session app,
# NOT frontend/app. Mirrors FRONTEND_BASE_URL discipline: explicit per env.
CANDIDATE_SESSION_BASE_URL=http://localhost:3002

# Stuck-session reaper.
# Disable in tests / for local dev that doesn't want wallclock-driven sweeps.
# REAPER_ENABLED=true
# REAPER_INTERVAL_SECONDS=300         # how often the scheduler ticks
# REAPER_STUCK_THRESHOLD_SECONDS=900  # 15 min idle on state='active' -> error
