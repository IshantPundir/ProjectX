# === Nexus Backend Environment Variables ===
# Copy to .env and fill in real values for local development.

# App
DEBUG=true
ENVIRONMENT=development

# Database (asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/postgres

# Test database (separate DB, same PostgreSQL instance)
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/projectx_test

# Redis
REDIS_URL=redis://redis:6379/0

# Auth — ES256 JWKS verification
SUPABASE_JWKS_URL=http://127.0.0.1:54321/auth/v1/.well-known/jwks.json

# Candidate JWT signing secret — REQUIRED, no default.
# Generate with: openssl rand -hex 32
# Treat with the same sensitivity as a DB credential. Signs single-use
# candidate session JWTs (HS256, hardcoded in app/modules/auth/service.py).
CANDIDATE_JWT_SECRET=

# Notifications
NOTIFICATIONS_DRY_RUN=true

# LiveKit
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# AI — Anthropic
ANTHROPIC_API_KEY=

# --- OpenAI (Phase 2A) ---
OPENAI_API_KEY=
OPENAI_EXTRACTION_MODEL=gpt-5.2
OPENAI_EXTRACTION_EFFORT=medium

# STT — Deepgram
DEEPGRAM_API_KEY=

# TTS — Cartesia
CARTESIA_API_KEY=

# Notifications — Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@projectx.com

# Notifications — SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Observability
SENTRY_DSN=
# Langfuse LLM tracing — set LANGFUSE_BASE_URL + keys to enable.
#
# SELF-HOSTED ONLY. CLAUDE.md prohibits pointing at cloud.langfuse.com /
# *.langfuse.com in staging or production because LLM traces contain
# candidate PII (transcripts, evaluation scores) and AIVIA compliance
# forbids routing that data through a third-party sub-processor.
#
# In development, cloud is allowed but discouraged — the client refuses
# to configure against *.langfuse.com outside `ENVIRONMENT=development`.
#
# Self-hosted example (Docker Compose): http://langfuse-web:3000
# Local dev:                            http://127.0.0.1:3000
LANGFUSE_BASE_URL=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://127.0.0.1:3000","http://127.0.0.1:3001"]
