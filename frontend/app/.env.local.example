NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<from supabase status>
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# ─── LAN Testing ───
# To test from another device on the same network, replace 127.0.0.1
# with your machine's LAN IP (e.g., 192.168.1.100):
#
# NEXT_PUBLIC_SUPABASE_URL=http://192.168.1.100:54321
# NEXT_PUBLIC_API_URL=http://192.168.1.100:8000
#
# Find your LAN IP: ip addr show | grep "inet " | grep -v 127.0.0.1
