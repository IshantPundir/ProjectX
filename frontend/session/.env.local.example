# Required: backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Dev-only: uncomment to render the in-browser proctoring vision debug overlay
# (face count / gaze zone / head pose / blink / fps) over the candidate self-view.
# Strict opt-in: only the literal "1" enables it. MUST stay unset in production.
# Requires a dev-server restart to take effect.
# NEXT_PUBLIC_PROCTORING_DEBUG=1

# LiveKit SFU origin(s) for the candidate CSP connect-src. Leave UNSET in dev —
# the dev CSP already allows ws://localhost:* + http://localhost:* for the
# self-hosted SFU, and unset falls back to the LiveKit Cloud wildcards.
# Self-hosted production: set BOTH the wss:// and https:// origins
# (space-separated) — the livekit-client opens a WebSocket AND an https
# validate/prepareConnection fetch to the same host.
# NEXT_PUBLIC_LIVEKIT_WS_URL=wss://livekit.example.com https://livekit.example.com

# CSP origin for presigned recording/reel video + thumbnails (the public
# /recordings page). Default works for Cloudflare R2; set explicitly for AWS S3.
# Example (S3): https://<bucket>.s3.<region>.amazonaws.com
NEXT_PUBLIC_RECORDING_MEDIA_ORIGIN=https://*.r2.cloudflarestorage.com
